# NexGen SCM — Root environment example
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Google Cloud ─────────────────────────────
GCP_PROJECT_ID=nexgen-scm-2026
GCP_REGION=us-central1

# ── AlloyDB ──────────────────────────────────
ALLOYDB_DSN=postgresql://scm_app:YOUR_PASSWORD@/scm_db?host=/cloudsql/nexgen-scm-2026:us-central1:nexgen-scm-primary

# ── Pub/Sub ───────────────────────────────────
PUBSUB_TOPIC_ID=telemetry-raw
PUBSUB_INTELLIGENCE_SUB=intelligence-pull
PUBSUB_ANOMALY_TOPIC=anomaly-events

# ── Vertex AI ─────────────────────────────────
VERTEX_ENDPOINT_ID=nexgen-scm-endpoint
VERTEX_LOCATION=us-central1
ANOMALY_THRESHOLD=0.75

# ── Frontend ──────────────────────────────────
INTELLIGENCE_ENGINE_URL=https://nexgen-intelligence-XXXX-uc.a.run.app

# ── OpenTelemetry ─────────────────────────────
OTLP_ENDPOINT=localhost:4317
