# ══════════════════════════════════════════════
# Terraform (infra/)
# ══════════════════════════════════════════════
# Local tfvars (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Terraform state (use remote backend — GCS)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ══════════════════════════════════════════════
# Docker
# ══════════════════════════════════════════════
.dockerignore
*.tar.gz
*.img

# ══════════════════════════════════════════════
# Security — NEVER commit these
# ══════════════════════════════════════════════
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
service-account*.json
*credentials*.json
gcp-credentials.json
application_default_credentials.json
.google-credentials.json
google-services.json
GoogleService-Info.plist
firebase-adminsdk*.json
.snyk

# Secrets / API keys
.env*
!.env.example
secrets/
.secrets/

# ══════════════════════════════════════════════
