# ══════════════════════════════════════════════
# Node.js / Next.js (frontend/)
# ══════════════════════════════════════════════
node_modules/
**/node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
tsconfig.tsbuildinfo
.npm
.eslintcache
.cache
.parcel-cache

# Next.js env files (contain secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# ══════════════════════════════════════════════
# Python / FastAPI (services/intelligence/)
# ══════════════════════════════════════════════
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.spec
pip-log.txt
pip-delete-this-directory.txt
.eggs/

# Virtual environments
venv/
.venv/
ENV/
env/
.env/
virtualenv/

